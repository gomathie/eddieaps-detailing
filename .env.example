# Copy to `.env` for local dev and fill in values. In production, set the same
# keys as Cloudflare Pages secrets with a NUXT_ prefix (e.g. NUXT_ADMIN_PASSWORD_HASH).

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=change-me

# Secret used to sign sessions/tokens (generate with: openssl rand -hex 32).
JWT_SECRET=change-me

# SMTP email (optional — for sending notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Cloudflare Turnstile keys (https://dash.cloudflare.com/?to=/:account/turnstile)
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
